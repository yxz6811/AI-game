# ═══════════════════════════════════════════════════════════
# Brain A 真全双工（默认：本机 Comni MiniCPM-o 4.5）
# ═══════════════════════════════════════════════════════════
#
# 架构：
#   Brain A = Comni Audio Full-Duplex（听+说双流，本机 :8006）
#   Brain B = 本包 Intent Bridge → AIRI → minecraft-bot
#
# 启动见：demo/start-brain-a.sh 或 demo/voice-runtime/README.md

# 本机 Comni（会自动走浏览器旁路，不连公网 /v1/realtime）
MINICPM_REALTIME_URL=ws://127.0.0.1:8006/v1/realtime?mode=audio
COMNI_BRIDGE=1

# 公网试听（仅协议联调时改用；会连 Realtime WS，不是本地真双流）
# MINICPM_REALTIME_URL=wss://minicpmo45.modelbest.cn/v1/realtime?mode=audio
# COMNI_BRIDGE=0

# 人设：lively | calm
PERSONA_STYLE=lively

# 可选：覆盖默认队友人设
# MINICPM_SYSTEM_PROMPT=你是 Minecraft 队友 AIRI，简短口语回复；执行指令时说清楚在做什么。

# AIRI 事件总线
AIRI_WS_URL=ws://127.0.0.1:6121/ws
# AIRI_TOKEN=

# 0 = 真连 AIRI/Bot；1 = 只打印工具（无 MC 时冒烟）
DRY_RUN=0

# 跟随目标玩家名（须与 Minecraft 客户端用户名一致）
FOLLOW_PLAYER_NAME=Steve

# 旁路 HTTP（Comni 页注入脚本）
BRIDGE_PORT=8787

# 仅文本降级（关掉 Brain A 旁路联调）时才开：
# SKIP_MINICPM=1
